<section class="tab inventory-tab abilities {{tab.cssClass}}" data-tab="abilities" data-group="primary">
	<div class="inventory-list-container scrollable-inventory">

		<div class="inventory-category op-shadow">
			<!-- CABEÇALHO DA LISTA -->
			<div class="inventory-list-header">
				<span class="col-name">
					<i class="fa-solid fa-bolt"></i>
					{{localize "op.ability.plural"}}
				</span>
				<span class="col-prop" style="width: 100px;">{{localize "op.execution"}}</span>
				<span class="col-controls">
					{{#if editable}}
						<a
							class="item-control item-create"
							data-action="createDoc"
							title="{{localize 'op.addAbility'}}"
							data-document-class="Item"
							data-type="ability"
						>
							<i class="fas fa-plus"></i>
						</a>
					{{/if}}
				</span>
			</div>

			<!-- LISTA DE HABILIDADES -->
			<ol class="inventory-items-list">
				{{#each abilities as |item|}}
					<li
						class="item item-row draggable"
						data-document-class="Item"
						data-item-id="{{item._id}}"
						style="display: flex; flex-direction: column; height: auto;"
					>
						<div class="item-row-main" style="width: 100%; align-items: center;">

							<!-- IDENTIDADE DA HABILIDADE -->
							<div class="item-identity flexrow">
								<div class="item-image slide">
									<a class="rollable" data-action="onRoll">
										<img src="{{item.img}}" title="{{item.name}}" width="24" height="24" />
									</a>
								</div>
								<!-- Nome clicável para expandir descrição -->
								<span
									class="item-name item-toggle rollable pointer"
									data-action="toggleDescription"
									style="cursor: pointer;"
									data-tooltip="{{item.name}}"
								>
									{{item.name}}
								</span>
							</div>

							<!-- EXECUÇÃO -->
							<div class="item-meta-col col-prop" style="width: 100px;">
								<span class="badge-cat">{{item.activationLabel}}</span>
							</div>

							<!-- CONTROLES -->
							<div class="item-meta-col col-controls">
								<a class="item-btn item-edit" data-action="viewDoc" title="{{localize 'op.edit'}}">
									<i class="fas fa-edit"></i>
								</a>
								<a class="item-btn btn-delete" data-action="deleteDoc" title="{{localize 'op.delete'}}">
									<i class="fas fa-trash"></i>
								</a>
							</div>
						</div>
					</li>
				{{else}}
					<!-- MENSAGEM CASO VAZIO -->
					<li class="item item-row">
						<div class="item-row-main" style="justify-content: center; color: #777;">
							{{localize "op.noAbilities"}}
						</div>
					</li>
				{{/each}}
			</ol>
		</div>

		<!-- HABILIDADES DIVERSAS (ProseMirror Padrão Dossiê) -->
		<div class="inventory-category dossier-section op-shadow" style="margin-top: 12px;">
			<div class="inventory-list-header">
				<span class="col-name"><i class="fa-solid fa-book-journal-whills"></i> {{localize "op.ability.diverse"}}</span>
			</div>

			<div class="dossier-editor-container">
				{{#if editable}}
					<prose-mirror
						name="system.temporary.abilities"
						data-document-u-u-i-d="{{actor.uuid}}"
						value="{{system.temporary.abilities}}"
						collaborate="true"
						toggled="true"
					>
						{{{enrichedAbilities}}}
					</prose-mirror>
				{{else}}
					<div class="locked-content">
						{{{enrichedAbilities}}}
					</div>
				{{/if}}
			</div>
		</div>

	</div>
</section>