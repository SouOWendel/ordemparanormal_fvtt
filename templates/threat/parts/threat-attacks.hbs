<section class="tab inventory-tab attacks {{tab.cssClass}}" data-tab="attacks" data-group="primary">
	<div class="inventory-list-container scrollable-inventory">

		<div class="inventory-category op-shadow">
			<!-- CABEÇALHO DA LISTA -->
			<div class="inventory-list-header">
				<span class="col-name">
					<i class="fa-solid fa-crosshairs"></i>
					{{localize "op.attack"}}
					/
					{{localize "op.armament"}}
				</span>
				<span class="col-prop" style="width: 100px;">{{localize "op.test"}}</span>
				<span class="col-prop" style="width: 150px;">{{localize "op.damage"}}</span>
				<span class="col-controls">
					{{#if editable}}
						<a
							class="item-control item-create"
							data-action="createDoc"
							title="{{localize 'op.addAttackArmament'}}"
							data-document-class="Item"
							data-type="armament"
						>
							<i class="fas fa-plus"></i>
						</a>
					{{/if}}
				</span>
			</div>

			<!-- LISTA DE ATAQUES -->
			<ol class="inventory-items-list">
				{{#each attacks as |item|}}
					<li
						class="item item-row draggable"
						data-document-class="Item"
						data-item-id="{{item._id}}"
						style="display: flex; flex-direction: column; height: auto;"
					>
						<div class="item-row-main" style="width: 100%; align-items: center;">

							<!-- IDENTIDADE DO ATAQUE (Foto + Nome + Dado) -->
							<div class="item-identity flexrow">
								<div class="item-image slide">
									<img
										src="{{item.img}}"
										title="{{item.name}}"
										class="item-toggle"
										style="cursor: pointer;"
										width="24"
										height="24"
									/>
									<a class="rollable" data-roll-type="item" data-action="onRoll">
										<i class="fa-solid fa-dice-d20"></i>
									</a>
								</div>
								<span class="item-name item-toggle" style="cursor: pointer;" data-tooltip="{{item.name}}">
									{{item.name}}
								</span>
							</div>

							<!-- TESTE DE ATAQUE -->
							<div class="item-meta-col col-prop" style="width: 100px;">
								<span class="badge-cat">{{item.attackLabel}}</span>
							</div>

							<!-- DANO DO ATAQUE -->
							<div class="item-meta-col col-prop" style="width: 150px;">
								<span class="badge-cat highlight">{{item.damageLabel}}</span>
							</div>

							<!-- CONTROLES -->
							<div class="item-meta-col col-controls">
								<a class="item-btn item-edit" data-action="viewDoc" title="Editar Item">
									<i class="fas fa-edit"></i>
								</a>
								<a class="item-btn btn-delete" data-action="deleteDoc" title="Apagar Item">
									<i class="fas fa-trash"></i>
								</a>
							</div>
						</div>
					</li>
				{{else}}
					<!-- MENSAGEM CASO VAZIO -->
					<li class="item item-row">
						<div class="item-row-main" style="justify-content: center; color: #777;">
							{{localize "op.noAttacks"}}
						</div>
					</li>
				{{/each}}
			</ol>
		</div>

	</div>
</section>