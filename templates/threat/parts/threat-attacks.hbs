<section class="tab flexcol attacks {{tab.cssClass}}" data-tab="attacks" data-group="primary">
	<ol class="items-list">
		<li class="item flexrow items-header">
			<div class="item-name">{{localize "op.attack"}} / {{localize "op.armament"}}</div>
			<div class="item-formula" style="flex: 0 0 110px; text-align: center;">{{localize "op.test"}}</div>
			<div class="item-formula" style="flex: 0 0 150px; text-align: center;">{{localize "op.damage"}}</div>
			<div class="item-controls">
				{{#if editable}}
				<a
					class="item-control item-create"
					data-action="createThreatAttack"
					title="{{localize 'op.addThreatAttack'}}"
				>
					<i class="fas fa-plus"></i>
				</a>
				{{/if}}
			</div>
		</li>
		{{#each attacks as |item|}}
		<li class="item flexrow draggable" data-drag="true" data-document-class="Item" data-item-id="{{item._id}}">
			<div class="item-name">
				<div class="item-image slide">
					<img src="{{item.img}}" title="{{item.name}}" width="24" height="24" />
					<a class="rollable" data-roll-type="item" data-action="onRoll">
						<i class="fa-solid fa-dice-d20"></i>
					</a>
				</div>
				<div style="display:flex;align-items:center;gap:4px;flex:1;min-width:0;">
					<span class="op-action-badge {{item.actionTypeBadge.cls}}">{{item.actionTypeBadge.label}}</span>
					<h4 style="margin:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">
						{{item.name}}{{#if (gt item.numberOfAttacks 1)}} x{{item.numberOfAttacks}}{{/if}}
						{{#if item.rangeCategoryLabel}}<span style="font-size:10px;opacity:0.7;margin-left:2px;">({{item.rangeCategoryLabel}})</span>{{/if}}
					</h4>
				</div>
			</div>
			<div class="item-formula item-prop" style="flex: 0 0 110px; text-align: center; font-size: 11px;">
				{{item.attackLabel}}
			</div>
			<div class="item-formula item-prop" style="flex: 0 0 150px; text-align: center; font-size: 11px;">
				{{item.damageLabel}}
			</div>
			<div class="item-controls">
				{{#if ../editable}}
				<a class="item-control" data-action="editThreatAttack" title="{{localize 'op.editThreatAttack'}}"><i class="fas fa-edit"></i></a>
				<a class="item-control" data-action="deleteDoc" title="{{localize 'op.delete'}}"><i class="fas fa-trash"></i></a>
				{{/if}}
			</div>
		</li>
		{{else}}
		<li class="item flexrow">
			<div class="item-name" style="padding: 10px; color: #777;">
				{{localize "op.noAttacks"}}
			</div>
		</li>
		{{/each}}
	</ol>
</section>
