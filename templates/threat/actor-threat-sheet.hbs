<section class="{{actor.type}} threat flexcol" id="threat" autocomplete="off">
	<header class="sheet-header-op">

		<!-- IDENTIDADE E STATUS PRINCIPAIS -->
		<div class="header-identify align-center flex">
			<img
				class="threat-profile-img"
				src="{{actor.img}}"
				data-edit="img"
				data-action="onEditImage"
				title="{{actor.name}}"
			/>

			<div class="identity-info flexcol">
				<h1 class="charname">
					<input name="name" type="text" value="{{actor.name}}" placeholder="{{localize 'op.threatName'}}" />
				</h1>

				<div class="header-stats-row">
					<div class="vd-box">
						<label>{{localize "op.VD"}}</label>
						<input
							type="number"
							name="system.attributes.vd.value"
							value="{{system.attributes.vd.value}}"
							data-dtype="Number"
						/>
					</div>

					<div class="disturbing-presence">
						<label class="section-title">{{localize "op.attPre"}}:</label>

						<div class="presence-stat">
							<label>DT</label>
							<input
								type="number"
								name="system.disturbingPresence.dt"
								value="{{system.disturbingPresence.dt}}"
								placeholder="0"
							/>
						</div>

						<div class="presence-stat">
							<label>{{localize "op.damage"}}</label>
							<input
								type="text"
								name="system.disturbingPresence.mentalDamage"
								value="{{system.disturbingPresence.mentalDamage}}"
								placeholder="Ex: 2d6"
							/>
							<i
								class="fa-solid fa-brain rollable pointer"
								data-action="onRollMentalDamage"
								title="{{localize 'op.rollMentalDamage'}}"
							></i>
						</div>
					</div>
				</div>
			</div>
		</div>

		<div class="header-fields">
			<!-- COMBATE -->
			<div class="combat-stats-row flexrow">
				<div class="resource hp-box">
					<label class="resource-label">{{localize "op.PV"}}</label>
					<div class="resource-content flexrow flex-center">
						<input type="text" name="system.attributes.hp.value" value="{{system.attributes.hp.value}}" data-dtype="Number" />
						<span class="divider">/</span>
						<input type="text" name="system.attributes.hp.max" value="{{system.attributes.hp.max}}" data-dtype="Number" />
					</div>
				</div>
				<div class="resource defense-box">
					<label class="resource-label">{{localize "op.defense"}}</label>
					<div class="resource-content">
						<input type="text" name="system.defense.value" value="{{system.defense.value}}" data-dtype="Number" />
					</div>
				</div>
				<div class="resource movement-box">
					<label class="resource-label">{{localize "op.deslocamento"}}</label>
					<div class="resource-content">
						<input
							type="text"
							name="system.attributes.movement.walk"
							value="{{system.attributes.movement.walk}}"
							data-dtype="String"
						/>
					</div>
				</div>
			</div>

			<!-- CLASSIFICAÇÃO E ATRIBUTOS (Linha Única) -->
			<div class="class-attr-row">
				<!-- Classificação -->
				<div class="resource select-box">
					<label class="resource-label" title="{{localize 'op.type'}}">{{localize "op.type"}}</label>
					<select name="system.details.creatureType">
						{{selectOptions threatTypes selected=system.details.creatureType localize=true}}
					</select>
				</div>
				<div class="resource select-box">
					<label class="resource-label" title="{{localize 'op.element'}}">{{localize "op.element"}}</label>
					<select name="system.details.element">
						{{selectOptions elements selected=system.details.element localize=true}}
					</select>
				</div>
				<div class="resource select-box">
					<label class="resource-label" title="{{localize 'op.size'}}">{{localize "op.size"}}</label>
					<select name="system.details.size">
						{{selectOptions threatSizes selected=system.details.size localize=true}}
					</select>
				</div>

				<!-- Atributos Base -->
				<div class="resource attr-box">
					<label
						class="resource-label rollable pointer"
						data-action="onRollAttributeTest"
						data-rollType="attribute"
						data-key="dex"
						title="{{localize 'op.attDex'}}"
					>AGI</label>
					<div class="resource-content"><input
							type="text"
							name="system.attributes.dex.value"
							value="{{system.attributes.dex.value}}"
							data-dtype="Number"
						/></div>
				</div>
				<div class="resource attr-box">
					<label
						class="resource-label rollable pointer"
						data-action="onRollAttributeTest"
						data-rollType="attribute"
						data-key="str"
						title="{{localize 'op.attStr'}}"
					>FOR</label>
					<div class="resource-content"><input
							type="text"
							name="system.attributes.str.value"
							value="{{system.attributes.str.value}}"
							data-dtype="Number"
						/></div>
				</div>
				<div class="resource attr-box">
					<label
						class="resource-label rollable pointer"
						data-action="onRollAttributeTest"
						data-rollType="attribute"
						data-key="int"
						title="{{localize 'op.attInt'}}"
					>INT</label>
					<div class="resource-content"><input
							type="text"
							name="system.attributes.int.value"
							value="{{system.attributes.int.value}}"
							data-dtype="Number"
						/></div>
				</div>
				<div class="resource attr-box">
					<label
						class="resource-label rollable pointer"
						data-action="onRollAttributeTest"
						data-rollType="attribute"
						data-key="pre"
						title="{{localize 'op.attPre'}}"
					>PRE</label>
					<div class="resource-content"><input
							type="text"
							name="system.attributes.pre.value"
							value="{{system.attributes.pre.value}}"
							data-dtype="Number"
						/></div>
				</div>
				<div class="resource attr-box">
					<label
						class="resource-label rollable pointer"
						data-action="onRollAttributeTest"
						data-rollType="attribute"
						data-key="vit"
						title="{{localize 'op.attVit'}}"
					>VIG</label>
					<div class="resource-content"><input
							type="text"
							name="system.attributes.vit.value"
							value="{{system.attributes.vit.value}}"
							data-dtype="Number"
						/></div>
				</div>
			</div>

			<!-- PERÍCIAS (MANTÉM O CÓDIGO ORIGINAL DAS PERÍCIAS AQUI) -->
			<div class="threat-skills-container">
				{{#each system.skills as |skill key|}}
					<div class="skill-box resource flex-group-center">
						{{#if (eq key "freeSkill")}}
							<div class="free-skill-header flexrow flex-center">
								<input
									type="text"
									name="system.skills.{{key}}.name"
									value="{{skill.name}}"
									placeholder="{{localize 'op.skill.freeSkill'}}"
								/>
								<i
									class="fas fa-dice rollable pointer compendium-event-contextmenu"
									data-action="onRollSkillCheck"
									data-key="{{key}}"
									data-roll="{{skill.formula}}"
									data-label="{{skill.label}}"
								></i>
							</div>
						{{else}}
							<label
								class="resource-label rollable pointer compendium-event-contextmenu"
								data-action="onRollSkillCheck"
								data-key="{{key}}"
								data-label="{{skill.label}}"
								data-rollType="skill"
							>
								{{skill.label}}
								<span>({{lookup skill.attr 0}})</span>
							</label>
						{{/if}}

						<div class="skill-controls item-prop flexrow">
							{{#if @root.owner}}<a
									class="adjustment-button"
									data-action="decrease"
									data-property="system.skills.{{key}}.degree.value"
								><i class="fas fa-minus"></i></a>{{/if}}
							<input
								type="number"
								value="{{skill.degree.value}}"
								placeholder="0"
								data-dtype="Number"
								data-name="system.skills.{{key}}.degree.value"
								inputmode="numeric"
							/>
							{{#if @root.owner}}<a
									class="adjustment-button"
									data-action="increase"
									data-property="system.skills.{{key}}.degree.value"
								><i class="fas fa-plus"></i></a>{{/if}}
						</div>
					</div>
				{{/each}}
			</div>

			<!-- TAGS (RESISTÊNCIAS E CARACTERÍSTICAS LADO A LADO) -->
			<div class="threat-tags flexrow">
				<!-- Alterado para flexrow -->
				<!-- Resistências -->
				<div class="resource tags-box">
					<label class="resource-label config-header">
						<a class="config-button" data-action="openResistanceConfig" title="{{localize 'op.resistancesTitle'}}">
							<i class="fas fa-shield-alt"></i>
							{{localize "op.resistances"}}
							<i class="fas fa-cog"></i>
						</a>
					</label>
					<div class="resource-content resistance-container-grid">
						{{#each viewResistances as |res key|}}
							{{#if res.isVisible}}
								<span class="resistance-tag" title="{{res.translatedLabel}}">
									<span class="resistance-tag-label">{{res.translatedLabel}}</span>
									<span class="resistance-tag-values">
										{{#if (gt res.value 0)}}<span class="resistance-tag-value">{{res.value}}</span>{{/if}}
										{{#if res.immune}}<i
												class="fas fa-shield-alt resistance-tag-immune"
												title="{{localize 'op.immune'}}"
											></i>{{/if}}
										{{#if res.vulnerable}}<i
												class="fas fa-heart-broken resistance-tag-vulnerable"
												title="{{localize 'op.vulnerable'}}"
											></i>{{/if}}
									</span>
								</span>
							{{/if}}
						{{/each}}
					</div>
				</div>

				<!-- Características -->
				<div class="resource tags-box">
					<label class="resource-label config-header">
						<a class="config-button" data-action="openTraitsConfig" title="{{localize 'op.traitsTitle'}}">
							<i class="fa-solid fa-list"></i>
							{{localize "op.traitsLabel"}}
							<i class="fas fa-cog"></i>
						</a>
					</label>
					<div class="resource-content traits-container-grid">
						{{#each viewTraits as |trait key|}}
							{{#if trait.isVisible}}
								<span class="traits-tag" title="{{trait.translatedLabel}}">
									<span class="traits-tag-label">{{trait.translatedLabel}}</span>
								</span>
							{{/if}}
						{{/each}}
					</div>
				</div>
			</div>

		</div>
	</header>
</section>