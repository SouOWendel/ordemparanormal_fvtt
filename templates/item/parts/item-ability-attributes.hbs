<section class="tab ability {{tab.cssClass}} scrollable" data-group="primary" data-tab="abilityAttr">
	<div class="content-item">

		<div class="class-attributes-section op-shadow">
			<div class="section-title">Configurações de Habilidade</div>

			<div class="grid" style="grid-template-columns: 120px 1fr; gap: 10px; align-items: center;">
				<label class="resource-label">{{localize "op.powerType"}}</label>
				<select name="system.abilityType" data-dtype="String">
					{{selectOptions optionPowerType selected=system.abilityType localize=true blank="—"}}
				</select>

				<label class="resource-label">{{localize "op.execution"}}</label>
				<select name="system.activation" data-dtype="String">
					{{selectOptions optionExecution selected=system.activation localize=true blank="—"}}
				</select>

				<label class="resource-label">{{localize "op.cost"}}</label>
				<input type="text" name="system.cost" value="{{system.cost}}" data-dtype="Number" />
			</div>
		</div>

	</div>
</section>