<section class="tab path {{tab.cssClass}} scrollable" data-group="primary" data-tab="pathAttr">
	<div class="grid">
		<label class="resource-label">{{localize "op.trilhasName"}}</label>
		<select name="system.pathType" data-dtype="String">
			{{selectOptions optionPaths selected=system.pathType localize=true blank="—"}}
		</select>

		<label class="resource-label">{{localize "op.preRequisite"}}</label>
		<input type="text" name="system.preRequisite" value="{{system.preRequisite}}" />
	</div>
</section>