		<label class="resource-label">{{localize "op.preRequisite"}}</label>
		<input type="text" name="system.preRequisite" value="{{system.preRequisite}}" />

		<label class="resource-label">{{localize "op.pathAbilities"}}</label>
		<textarea name="system.abilities">{{system.abilities}}</textarea>
	</div>
</section>