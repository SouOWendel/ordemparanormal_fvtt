<section class="tab ritual {{tab.cssClass}}" data-group="primary" data-tab="ritualAttr">
	<div class="content-item scrollable" style="padding: 10px;">

		<div class="class-attributes-section">
			<div class="section-title">Atributos de Ritual</div>

			<div class="grid" style="display: grid; grid-template-columns: 120px 1fr; gap: 10px; align-items: center;">

				<label class="resource-label">{{localize "op.circle"}}</label>
				<div class="categoryCheck">
					{{radioBoxes "system.circle" degree checked=system.circle}}
				</div>

				<label class="resource-label">{{localize "op.element"}}</label>
				<select name="system.element">{{selectOptions
						optionElement
						selected=system.element
						localize=true
						blank="—"
					}}</select>

				<label class="resource-label">{{localize "op.execution"}}</label>
				<select name="system.execution">{{selectOptions
						optionExecution
						selected=system.execution
						localize=true
						blank="—"
					}}</select>

				<label class="resource-label">{{localize "op.range"}}</label>
				<select name="system.range">{{selectOptions optionRange selected=system.range localize=true blank="—"}}</select>

				<label class="resource-label">{{localize "op.target"}}</label>
				<div style="display: flex; gap: 5px;">
					<select name="system.target">{{selectOptions optionTarget selected=system.target localize=true blank="—"}}</select>
					{{#ifEquals system.target "people"}}<input
							type="text"
							name="system.targetQtd"
							value="{{system.targetQtd}}"
							placeholder="Qtd"
						/>{{/ifEquals}}
				</div>

				<label class="resource-label">{{localize "op.duration"}}</label>
				<select name="system.duration">{{selectOptions
						optionDuration
						selected=system.duration
						localize=true
						blank="—"
					}}</select>

				<label class="resource-label">Formas</label>
				<div style="display: flex; gap: 20px; padding-left: 5px;">
					<label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
						<input
							type="checkbox"
							name="system.studentForm"
							{{checked system.studentForm}}
							style="width: 16px; height: 16px;"
						/>
						{{localize "op.studentForm"}}
					</label>
					<label style="display: flex; align-items: center; gap: 8px; cursor: pointer;">
						<input type="checkbox" name="system.trueForm" {{checked system.trueForm}} style="width: 16px; height: 16px;" />
						{{localize "op.trueForm"}}
					</label>
				</div>
			</div>
		</div>

	</div>
</section>