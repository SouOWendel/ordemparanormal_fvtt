<section class="tab origin {{tab.cssClass}} scrollable" data-group="primary" data-tab="originAttr">
	<div class="content-item" style="padding: 10px;">

		<div class="class-attributes-section">
			<div class="section-title">Atributos de Origem</div>

			<div class="grid" style="display: grid; grid-template-columns: 1fr; gap: 10px;">

				<div class="form-group">
					<label class="resource-label">{{localize "op.originSkills"}}</label>
					<textarea
						name="system.grantedSkills"
						rows="4"
						style="width: 100%; resize: vertical;"
					>{{system.grantedSkills}}</textarea>
				</div>

				<div class="form-group">
					<label class="resource-label">{{localize "op.originAbility"}}</label>
					<textarea name="system.ability" rows="4" style="width: 100%; resize: vertical;">{{system.ability}}</textarea>
				</div>

			</div>
		</div>

	</div>
</section>