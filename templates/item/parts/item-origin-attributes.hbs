<section class="tab origin {{tab.cssClass}} scrollable" data-group="primary" data-tab="originAttr">
	<div class="grid">
		<label class="resource-label">{{localize "op.originName"}}</label>
		<select name="system.originType" data-dtype="String">
			{{selectOptions optionOrigins selected=system.originType localize=true blank="—"}}
		</select>

		<label class="resource-label">{{localize "op.preRequisite"}}</label>
		<input type="text" name="system.preRequisite" value="{{system.preRequisite}}" />
	</div>
</section>