<section class="tab armament {{tab.cssClass}} scrollable" data-group="primary" data-tab="armamentSpec">
	<div class="content-item">
		<fieldset class="armament-fieldset op-shadow">
			<legend><i class="fas fa-list-ul"></i> Especificações</legend>
			<div class="resource grid grid-2col">
				<label class="resource-label">{{localize "op.category"}}</label>
				<div class="categoryCheck">
					{{radioBoxes "system.category" categories checked=system.category}}
				</div>
			</div>
			<div class="armament-grid-2">
				<div class="armament-field">
					<label>{{localize "op.proficiency"}}</label>
					<select name="system.proficiency">{{selectOptions
							optionProficiency
							selected=system.proficiency
							localize=true
							blank="—"
						}}</select>
				</div>
				<div class="armament-field">
					<label>{{localize "op.gripType"}}</label>
					<select name="system.types.gripType">{{selectOptions
							optionGripType
							selected=system.types.gripType
							localize=true
							blank="—"
						}}</select>
				</div>
			</div>
		</fieldset>

		<fieldset class="armament-fieldset op-shadow">
			<legend><i class="fas fa-tags"></i> Condições</legend>
			<div class="checkbox-grid">
				<label class="checkbox-pill"><input
						type="checkbox"
						name="system.conditions.improvised"
						{{checked system.conditions.improvised}}
					/>
					<span>Improvisada</span></label>
				<label class="checkbox-pill"><input
						type="checkbox"
						name="system.conditions.throwable"
						{{checked system.conditions.throwable}}
					/>
					<span>Arremessável</span></label>
				<label class="checkbox-pill"><input
						type="checkbox"
						name="system.conditions.agile"
						{{checked system.conditions.agile}}
					/>
					<span>Arma Ágil</span></label>
				<label class="checkbox-pill"><input
						type="checkbox"
						name="system.conditions.automatic"
						{{checked system.conditions.automatic}}
					/>
					<span>Automática</span></label>
				<label class="checkbox-pill"><input
						type="checkbox"
						name="system.conditions.adaptableGrip"
						{{checked system.conditions.adaptableGrip}}
					/>
					<span>Empunhadura Adapt.</span></label>
				<label class="checkbox-pill"><input
						type="checkbox"
						name="system.conditions.pistolBlow"
						{{checked system.conditions.pistolBlow}}
					/>
					<span>Coronhada</span></label>
			</div>
		</fieldset>
	</div>
</section>