<section class="tab flexcol rituals-tab inventory-tab {{tab.cssClass}}" data-tab="rituals" data-group="primary">

	{{! CABEÇALHO SUPERIOR: DT DO RITUAL }}
	<header class="inventory-ritual-header" style="justify-content: center; padding: 12px;">
		<div class="ritual-box" style="flex-direction: row; align-items: center; gap: 10px;">
			<span class="label"><i class="fas fa-book-skull"></i> {{localize "op.ritualdt"}}</span>
			<span class="badge-ritual"> {{system.ritual.DT}} </span>
		</div>
	</header>

	{{! CORPO PRINCIPAL: LISTA DE RITUAIS }}
	<div class="inventory-list-container scrollable-inventory">

		{{! LOOP: RITUAIS VÁLIDOS POR CÍRCULO }}
		{{#each rituals.valid as |rituals circle|}}
			<div class="inventory-category op-shadow">

				{{! Cabeçalho da Categoria (Ex: 1º Círculo) }}
				<div class="inventory-list-header items-header">
					<span class="col-name">
						{{#ifEquals circle 5}}
							<i class="fas fa-book-journal-whills"></i>
							Rituais Especiais
						{{else}}
							<i class="fas fa-circle-nodes"></i>
							{{circle}}º
							{{localize "op.circle"}}
							-
							{{#ifEquals circle 1}}1 {{@root.costLabel}}{{/ifEquals}}
							{{#ifEquals circle 2}}3 {{@root.costLabel}}{{/ifEquals}}
							{{#ifEquals circle 3}}6 {{@root.costLabel}}{{/ifEquals}}
							{{#ifEquals circle 4}}10 {{@root.costLabel}}{{/ifEquals}}
						{{/ifEquals}}
					</span>

					<span class="col-range">{{localize "op.range"}}</span>
					<span class="col-target">{{localize "op.target"}}</span>
					<span class="col-duration">{{localize "op.duration"}}</span>
					<span class="col-resist">{{localize "op.resistance"}}</span>

					<span class="col-controls-mini">
						{{#if @root.editable}}
							<a
								class="item-control item-create"
								title="Criar ritual de {{circle}}º círculo"
								data-action="createDoc"
								data-document-class="Item"
								data-type="ritual"
								data-system.circle="{{circle}}"
							>
								<i class="fas fa-plus"></i>
							</a>
						{{/if}}
					</span>
				</div>

				{{! Lista de Itens do Círculo }}
				<ol class="inventory-items-list main-items">
					{{#each rituals as |item id|}}
						<li class="item item-row draggable" data-document-class="Item" data-item-id="{{item._id}}">
							<div class="item-row-main">

								{{! Identidade (Imagem + Nome) }}
								<div class="item-identity flexrow">
									<div class="item-image slide">
										<img src="{{item.img}}" title="{{item.name}}" class="item-toggle" style="cursor: pointer;" />
										<a class="rollable" data-roll-type="item" data-action="onRoll"><i class="fa-solid fa-dice-d20"></i></a>
									</div>
									<span class="item-name item-toggle" style="cursor: pointer;" data-tooltip="{{item.name}}">{{item.name}}</span>
								</div>

								{{! Colunas de Informação }}
								<div class="item-meta-col col-range">
									<span class="badge-cat">{{#if item.system.range}}{{localize
												(concat "op.rangeChoices." item.system.range)
											}}{{else}}—{{/if}}</span>
								</div>

								<div class="item-meta-col col-target">
									<span class="badge-cat">
										{{#if item.system.target}}
											{{item.system.targetQtd}}
											<span class="lowercase">{{localize (concat "op.targetChoices." item.system.target)}}</span>
										{{else}}—{{/if}}
									</span>
								</div>

								<div class="item-meta-col col-duration">
									<span class="badge-cat">{{#if item.system.duration}}{{localize
												(concat "op.durationChoices." item.system.duration)
											}}{{else}}—{{/if}}</span>
								</div>

								<div class="item-meta-col col-resist">
									<span class="badge-cat">
										{{#if item.system.resistance}}
											{{#if item.system.skillResis}}{{localize (concat "op.skill." item.system.skillResis)}} {{/if}}
											{{localize (concat "op.resistanceChoices." item.system.resistance)}}
										{{else}}—{{/if}}
									</span>
								</div>

								{{! Controles }}
								<div class="item-meta-col col-controls-mini">
									<a class="item-btn item-edit" data-action="viewDoc" title="Editar Item"><i class="fas fa-edit"></i></a>
									<a class="item-btn btn-delete" data-action="deleteDoc" title="Apagar Item"><i class="fas fa-trash"></i></a>
								</div>
							</div>

							{{! Descrição Oculta/Expansível }}
							<div class="item-description">
								<div class="description-body-content">{{{item.system.description}}}</div>
							</div>
						</li>
					{{/each}}
				</ol>
			</div>
		{{/each}}

		{{! ITENS INVÁLIDOS / OUTROS }}
		{{#if rituals.invalid}}
			<div class="inventory-category invalid-category">
				<div class="inventory-list-header alert-header">
					<span class="col-name"><i class="fas fa-triangle-exclamation"></i> Outros Rituais</span>
					<span class="col-range">{{localize "op.range"}}</span>
					<span class="col-target">{{localize "op.area"}}</span>
					<span class="col-duration">{{localize "op.duration"}}</span>
					<span class="col-resist">{{localize "op.resistance"}}</span>
					<span class="col-controls-mini">
						{{#if @root.editable}}
							<a class="item-control item-create" data-action="createDoc" title="Criar Ritual Especial" data-type="ritual">
								<i class="fas fa-plus"></i>
							</a>
						{{/if}}
					</span>
				</div>
				<ol class="inventory-items-list main-items">
					{{#each rituals.invalid as |item id|}}
						<li class="item item-row draggable" data-document-class="Item" data-item-id="{{item._id}}">
							<div class="item-row-main">
								<div class="item-identity flexrow">
									<div class="item-image slide">
										<img src="{{item.img}}" title="{{item.name}}" class="item-toggle" style="cursor: pointer;" />
										<a class="rollable" data-roll-type="item" data-action="onRoll"><i class="fa-solid fa-dice-d20"></i></a>
									</div>
									<span class="item-name item-toggle" style="cursor: pointer;" data-tooltip="{{item.name}}">{{item.name}}</span>
								</div>

								<div class="item-meta-col col-range"><span class="badge-cat">{{item.system.range}}</span></div>
								<div class="item-meta-col col-target"><span class="badge-cat">{{item.system.areaEffect}}</span></div>
								<div class="item-meta-col col-duration"><span class="badge-cat">{{item.system.duration}}</span></div>
								<div class="item-meta-col col-resist"><span class="badge-cat">{{item.system.resistance}}</span></div>

								<div class="item-meta-col col-controls-mini">
									<a class="item-btn item-edit" data-action="viewDoc" title="Editar Item"><i class="fas fa-edit"></i></a>
									<a class="item-btn btn-delete" data-action="deleteDoc" title="Apagar Item"><i class="fas fa-trash"></i></a>
								</div>
							</div>
							<div class="item-description">
								<div class="description-body-content">{{{item.system.description}}}</div>
							</div>
						</li>
					{{/each}}
				</ol>
			</div>
		{{/if}}
	</div>
</section>