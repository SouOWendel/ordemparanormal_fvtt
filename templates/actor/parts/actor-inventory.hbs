<section class="tab inventory-tab {{tab.cssClass}}" data-tab="inventory" data-group="primary">

	<header class="inventory-prestige-header op-shadow">
		<div class="patent-box">
			<span class="label"><i class="fas fa-medal"></i> Patente</span>
			<input
				type="text"
				name="system.patent.name"
				value="{{system.patent.name}}"
				placeholder="Nome"
				class="patent-input"
				data-dtype="String"
				disabled
			/>
		</div>

		<div class="prestige-box">
			<span class="label"><i class="fas fa-id-badge"></i> Pontos de Prestígio</span>
			<input
				type="text"
				name="system.patent.prestigePoints"
				value="{{system.patent.prestigePoints}}"
				placeholder="0"
				class="prestige-input"
				data-dtype="Number"
			/>
		</div>

		<div class="category-limits">
			<span class="section-title"><i class="fas fa-shield-halved"></i> Limites por Categoria</span>
			<div class="limits-grid">
				<div class="limit-badge font-cat-1">
					<label>I</label>
					<input
						type="number"
						name="system.patent.itemLimit1"
						value="{{system.patent.itemLimit1}}"
						placeholder="0"
						data-dtype="Number"
						disabled
					/>
				</div>
				<div class="limit-badge font-cat-2">
					<label>II</label>
					<input
						type="number"
						name="system.patent.itemLimit2"
						value="{{system.patent.itemLimit2}}"
						placeholder="0"
						data-dtype="Number"
						disabled
					/>
				</div>
				<div class="limit-badge font-cat-3">
					<label>III</label>
					<input
						type="number"
						name="system.patent.itemLimit3"
						value="{{system.patent.itemLimit3}}"
						placeholder="0"
						data-dtype="Number"
						disabled
					/>
				</div>
				<div class="limit-badge font-cat-4">
					<label>IV</label>
					<input
						type="number"
						name="system.patent.itemLimit4"
						value="{{system.patent.itemLimit4}}"
						placeholder="0"
						data-dtype="Number"
						disabled
					/>
				</div>
			</div>
		</div>
	</header>

	<div class="inventory-list-container scrollable-inventory">

		<div class="inventory-category op-shadow">
			<div class="inventory-list-header">
				<span class="col-name"><i class="fa-solid fa-gun"></i> {{localize "op.armaments"}}</span>
				<span class="col-prop">Prof.</span>
				<span class="col-prop">Crit.</span>
				<span class="col-prop">Alcance</span>
				<span class="col-space">Espaço</span>
				<span class="col-controls">
					{{#if @root.editable}}
						<a
							class="item-control item-create"
							data-action="createDoc"
							title="{{localize 'DOCUMENT.Create' type="Armamento"}}"
							data-document-class="Item"
							data-type="armament"
						>
							<i class="fas fa-plus"></i>
						</a>
					{{/if}}
				</span>
			</div>

			<ol class="inventory-items-list">
				{{#each armament as |item id|}}
					<li
						class="item item-row draggable {{ternary item.system.using.active 'is-active' ''}}"
						data-document-class="Item"
						data-item-id="{{item._id}}"
						style="display: flex; flex-direction: column; height: auto;"
					>
						<div class="item-row-main" style="width: 100%; align-items: center;">

							<div class="item-identity flexrow">
								<div class="item-image slide">
									<img
										src="{{item.img}}"
										title="{{item.name}}"
										class="item-toggle"
										style="cursor: pointer;"
										width="24"
										height="24"
									/>
									<a class="rollable" data-roll-type="item" data-action="onRoll"><i class="fa-solid fa-dice-d20"></i></a>
								</div>
								<span class="item-name item-toggle" style="cursor: pointer;" data-tooltip="{{item.name}}">{{item.name}}</span>
							</div>

							<div class="item-meta-col col-prop">
								<span class="badge-cat">
									{{ternary
										item.system.proficiency
										(localize (concat "op.proficiencyChoicesAbbr." item.system.proficiency))
										"—"
									}}
								</span>
							</div>
							<div class="item-meta-col col-prop">
								<span class="badge-cat">{{ternary item.system.critical item.system.critical "—"}}</span>
							</div>
							<div class="item-meta-col col-prop">
								<span class="badge-cat">{{ternary item.system.range item.system.range "—"}}</span>
							</div>
							<div class="item-meta-col col-space item-editable-resource">
								<input
									class="inline-input"
									type="number"
									value="{{item.system.weight}}"
									data-dtype="Number"
									data-name="system.weight"
									inputmode="numeric"
									pattern="[0-9+=\-]*"
									min="0"
								/>
							</div>

							<div class="item-meta-col col-controls">
								<a class="item-btn" data-action="onSendChat" title="Enviar para o chat"><i class="fas fa-message"></i></a>
								<a class="item-btn btn-star" data-action="onMarkItem" title="Marcar como equipado"><i
										class="{{item.system.using.class}} fa-star"
									></i></a>
								<a class="item-btn" data-action="viewDoc" title="Editar Item"><i class="fas fa-edit"></i></a>
								<a class="item-btn btn-delete" data-action="deleteDoc" title="Apagar Item"><i class="fas fa-trash"></i></a>
							</div>
						</div>

						{{#if item.system.description}}
							<div class="item-description">
								<div class="description-body-content">
									{{{item.system.description}}}
								</div>
							</div>
						{{/if}}
					</li>
				{{/each}}
			</ol>
		</div>

		<div class="inventory-category op-shadow">
			<div class="inventory-list-header">
				<span class="col-name"><i class="fa-solid fa-screwdriver-wrench"></i>
					{{localize "op.generalEquipment.plural"}}</span>
				<span class="col-category">Cat.</span>
				<span class="col-space">Espaço</span>
				<span class="col-quantity">Qtd.</span>
				<span class="col-controls">
					{{#if @root.editable}}
						<a
							class="item-control item-create"
							data-action="createDoc"
							title="Criar Equipamento"
							data-document-class="Item"
							data-type="generalEquipment"
						>
							<i class="fas fa-plus"></i>
						</a>
					{{/if}}
				</span>
			</div>

			<ol class="inventory-items-list">
				{{#each generalEquip as |item id|}}
					<li
						class="item item-row draggable {{ternary item.system.using.active 'is-active' ''}}"
						data-document-class="Item"
						data-item-id="{{item._id}}"
						style="display: flex; flex-direction: column; height: auto;"
					>
						<div class="item-row-main" style="width: 100%; align-items: center;">

							<div class="item-identity flexrow">
								<div class="item-image slide">
									<img
										src="{{item.img}}"
										title="{{item.name}}"
										class="item-toggle"
										style="cursor: pointer;"
										width="24"
										height="24"
									/>
									<a class="rollable" data-action="onRoll" data-roll-type="item"><i class="fa-solid fa-dice-d20"></i></a>
								</div>
								<span class="item-name item-toggle" style="cursor: pointer;" data-tooltip="{{item.name}}">{{item.name}}</span>
							</div>

							<div class="item-meta-col col-category item-editable-resource">
								<input
									class="inline-input badge-cat-input"
									type="number"
									value="{{item.system.category}}"
									data-dtype="Number"
									data-name="system.category"
									inputmode="numeric"
									pattern="[0-9+=\-]*"
									min="0"
								/>
							</div>
							<div class="item-meta-col col-space item-editable-resource">
								<input
									class="inline-input"
									type="number"
									value="{{item.system.weight}}"
									data-dtype="Number"
									data-name="system.weight"
									inputmode="numeric"
									pattern="[0-9+=\-]*"
									min="0"
								/>
							</div>

							<div class="item-meta-col col-quantity item-editable-resource">
								<div class="quantity-controller">
									{{#if @root.owner}}
										<a class="adjustment-button" data-action="decrease" data-property="system.quantity"><i
												class="fas fa-minus"
											></i></a>
									{{/if}}
									<input
										class="inline-input qty-value"
										type="number"
										value="{{item.system.quantity}}"
										data-dtype="Number"
										data-name="system.quantity"
										inputmode="numeric"
										pattern="[0-9+=\-]*"
										min="0"
									/>
									{{#if @root.owner}}
										<a class="adjustment-button" data-action="increase" data-property="system.quantity"><i
												class="fas fa-plus"
											></i></a>
									{{/if}}
								</div>
							</div>

							<div class="item-meta-col col-controls">
								<a class="item-btn" data-action="onSendChat" title="Enviar para o chat"><i class="fas fa-message"></i></a>
								<a class="item-btn btn-star" data-action="onMarkItem" title="Marcar como equipado"><i
										class="{{item.system.using.class}} fa-star"
									></i></a>
								<a class="item-btn" data-action="viewDoc" title="Editar Item"><i class="fas fa-edit"></i></a>
								<a class="item-btn btn-delete" data-action="deleteDoc" title="Apagar Item"><i class="fas fa-trash"></i></a>
							</div>
						</div>

						{{#if item.system.description}}
							<div class="item-description">
								<div class="description-body-content">
									{{{item.system.description}}}
								</div>
							</div>
						{{/if}}
					</li>
				{{/each}}
			</ol>
		</div>

		<div class="inventory-category op-shadow">
			<div class="inventory-list-header">
				<span class="col-name"><i class="fa-solid fa-shield"></i> {{localize "op.protection.plural"}}</span>
				<span class="col-category">Defesa</span>
				<span class="col-space">Espaço</span>
				<span class="col-quantity">Qtd.</span>
				<span class="col-controls">
					{{#if @root.editable}}
						<a
							class="item-control"
							data-action="createDoc"
							title="Criar Proteção"
							data-document-class="Item"
							data-type="protection"
						>
							<i class="fas fa-plus"></i>
						</a>
					{{/if}}
				</span>
			</div>

			<ol class="inventory-items-list">
				{{#each protection as |item id|}}
					<li
						class="item item-row draggable {{ternary item.system.using.active 'is-active' ''}}"
						data-document-class="Item"
						data-item-id="{{item._id}}"
						style="display: flex; flex-direction: column; height: auto;"
					>
						<div class="item-row-main" style="width: 100%; align-items: center;">

							<div class="item-identity flexrow">
								<div class="item-image slide">
									<img
										src="{{item.img}}"
										title="{{item.name}}"
										class="item-toggle"
										style="cursor: pointer;"
										width="24"
										height="24"
									/>
									<a class="rollable" data-action="onRoll" data-roll-type="item"><i class="fa-solid fa-dice-d20"></i></a>
								</div>
								<span class="item-name item-toggle" style="cursor: pointer;" data-tooltip="{{item.name}}">{{item.name}}</span>
							</div>

							<div class="item-meta-col col-category">
								<span class="badge-cat">{{ternary item.system.defense item.system.defense "—"}}</span>
							</div>
							<div class="item-meta-col col-space item-editable-resource">
								<input
									class="inline-input"
									type="number"
									value="{{item.system.weight}}"
									data-dtype="Number"
									data-name="system.weight"
									inputmode="numeric"
									pattern="[0-9+=\-]*"
									min="0"
								/>
							</div>

							<div class="item-meta-col col-quantity item-editable-resource">
								<div class="quantity-controller">
									{{#if @root.owner}}
										<a class="adjustment-button" data-action="decrease" data-property="system.quantity"><i
												class="fas fa-minus"
											></i></a>
									{{/if}}
									<input
										class="inline-input qty-value"
										type="number"
										value="{{item.system.quantity}}"
										data-dtype="Number"
										data-name="system.quantity"
										inputmode="numeric"
										pattern="[0-9+=\-]*"
										min="0"
									/>
									{{#if @root.owner}}
										<a class="adjustment-button" data-action="increase" data-property="system.quantity"><i
												class="fas fa-plus"
											></i></a>
									{{/if}}
								</div>
							</div>

							<div class="item-meta-col col-controls">
								<a class="item-btn" data-action="onSendChat" title="Enviar para o chat"><i class="fas fa-message"></i></a>
								<a class="item-btn btn-star" data-action="onMarkItem" title="Marcar como equipado"><i
										class="{{item.system.using.class}} fa-star"
									></i></a>
								<a class="item-btn" data-action="viewDoc" title="Editar Item"><i class="fas fa-edit"></i></a>
								<a class="item-btn btn-delete" data-action="deleteDoc" title="Apagar Item"><i class="fas fa-trash"></i></a>
							</div>
						</div>

						{{#if item.system.description}}
							<div class="item-description">
								<div class="description-body-content">
									{{{item.system.description}}}
								</div>
							</div>
						{{/if}}
					</li>
				{{/each}}
			</ol>
		</div>

	</div>

	<footer class="inventory-footer-space {{ternary system.spaces.pctMax 'is-overburdened' ''}}">
		<div class="space-status-bar">
			<span class="space-label">
				<i class="fas fa-scale-unbalanced"></i>
				{{#if system.spaces.pctMax}}ALERTA: SOBREPESO DETECTADO{{else}}ESPAÇOS DO INVENTÁRIO{{/if}}
			</span>
			<div class="space-counter">
				<span class="current">{{system.spaces.value}}</span>
				<span class="divider">/</span>
				<span class="max">{{system.spaces.max}}</span>
			</div>
		</div>
		<div class="progress-bar-container">
			<div class="progress-fill" style="width: {{system.spaces.pct}}%;"></div>
		</div>
	</footer>

</section>