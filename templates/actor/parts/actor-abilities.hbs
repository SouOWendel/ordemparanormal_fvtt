<section class="tab flexcol abilities-tab inventory-tab {{tab.cssClass}}" data-tab="abilities" data-group="primary">
	<div class="tactical-control-bar">
		<a
			data-action="toggleResources"
			title="Gerenciar Recursos"
			class="toggle-btn {{ternary mostrarRecursos 'is-active' ''}}"
		>
			<i class="fas fa-boxes"></i>
			{{#if mostrarRecursos}}Ocultar Recursos{{else}}Gerir Recursos{{/if}}
		</a>
	</div>
	{{#if mostrarRecursos}}
		<div class="inventory-prestige-header resource-manager-box">
			<div
				class="category-limits"
				style="width: 100%; align-items: center; justify-content: center; flex-direction: row; gap: 15px;"
			>

				{{! Recurso 1 }}
				<div class="limit-badge resource-badge">
					<label><input
							type="text"
							name="system.resources.res1.label"
							value="{{system.resources.res1.label}}"
							placeholder="Recurso 1"
						/></label>
					<div class="resource-inputs">
						<input
							type="number"
							name="system.resources.res1.value"
							value="{{system.resources.res1.value}}"
							placeholder="0"
							data-dtype="Number"
						/>
						<span class="divider">/</span>
						<input
							type="number"
							name="system.resources.res1.max"
							value="{{system.resources.res1.max}}"
							placeholder="0"
							data-dtype="Number"
						/>
					</div>
				</div>

				{{! Recurso 2 }}
				<div class="limit-badge resource-badge">
					<label><input
							type="text"
							name="system.resources.res2.label"
							value="{{system.resources.res2.label}}"
							placeholder="Recurso 2"
						/></label>
					<div class="resource-inputs">
						<input
							type="number"
							name="system.resources.res2.value"
							value="{{system.resources.res2.value}}"
							placeholder="0"
							data-dtype="Number"
						/>
						<span class="divider">/</span>
						<input
							type="number"
							name="system.resources.res2.max"
							value="{{system.resources.res2.max}}"
							placeholder="0"
							data-dtype="Number"
						/>
					</div>
				</div>

				{{! Recurso 3 }}
				<div class="limit-badge resource-badge">
					<label><input
							type="text"
							name="system.resources.res3.label"
							value="{{system.resources.res3.label}}"
							placeholder="Recurso 3"
						/></label>
					<div class="resource-inputs">
						<input
							type="number"
							name="system.resources.res3.value"
							value="{{system.resources.res3.value}}"
							placeholder="0"
							data-dtype="Number"
						/>
						<span class="divider">/</span>
						<input
							type="number"
							name="system.resources.res3.max"
							value="{{system.resources.res3.max}}"
							placeholder="0"
							data-dtype="Number"
						/>
					</div>
				</div>

			</div>
		</div>
	{{/if}}

	<div class="inventory-list-container scrollable-inventory">
		{{#each abilities.valid as |section type|}}
			<div class="inventory-category op-shadow">
				<div class="inventory-list-header">
					<span class="col-name">
						<i class="fa-solid fa-bahai"></i>
						{{#ifEquals type 1}}{{localize "op.abilitiesAbv.origin"}}{{/ifEquals}}
						{{#ifEquals type 2}}{{localize "op.abilitiesAbv.class"}}{{/ifEquals}}
						{{#ifEquals type 3}}{{localize "op.abilitiesAbv.path"}}{{/ifEquals}}
						{{#ifEquals type 4}}{{localize "op.abilitiesAbv.paranormal"}}{{/ifEquals}}
						{{#ifEquals type 5}}{{localize "op.abilitiesAbv.general"}}{{/ifEquals}}
						{{#ifEquals type 6}}{{localize "op.abilitiesAbv.ability"}}{{/ifEquals}}
					</span>

					<span class="col-type">Tipo</span>
					<span class="col-cost">Custo</span>
					<span class="col-exec">Execução</span>

					<span class="col-controls">
						{{#if @root.editable}}
							<a
								class="item-control item-create"
								data-action="createDoc"
								title="Criar Habilidade"
								data-document-class="Item"
								data-type="ability"
								data-id="{{type}}"
								data-system.ability-Type="{{abilityTypeHelper type}}"
							>
								<i class="fas fa-plus"></i>
							</a>
						{{/if}}
					</span>
				</div>

				{{! LOOP DOS ITENS }}
				<ol class="inventory-items-list main-items">
					{{#each section as |item id|}}
						<li class="item item-row draggable" data-document-class="Item" data-item-id="{{item._id}}">
							<div class="item-row-main">

								{{! Identidade (Imagem + Nome) }}
								<div class="item-identity flexrow">
									<div class="item-image slide">
										<img src="{{item.img}}" title="{{item.name}}" class="item-toggle" style="cursor: pointer;" />
										<a class="rollable" data-roll-type="item" data-action="onRoll"><i class="fa-solid fa-dice-d20"></i></a>
									</div>
									<span class="item-name item-toggle" style="cursor: pointer;" data-tooltip="{{item.name}}">{{item.name}}</span>
								</div>

								{{! Colunas de Dados Estilizadas }}
								<div class="item-meta-col col-type">
									<span class="badge-cat">
										{{#if item.system.abilityType}}
											{{localize (concat "op.powerTypeChoices." item.system.abilityType)}}
										{{else}}—{{/if}}
									</span>
								</div>

								<div class="item-meta-col col-cost">
									<span class="badge-cat highlight">{{item.displayCost}}</span>
								</div>

								<div class="item-meta-col col-exec">
									<span class="badge-cat">{{item.activationLabel}}</span>
								</div>

								{{! Controles }}
								<div class="item-meta-col col-controls">
									<a class="item-btn item-edit" data-action="viewDoc" title="Editar Item"><i class="fas fa-edit"></i></a>
									<a class="item-btn btn-delete" data-action="deleteDoc" title="Apagar Item"><i class="fas fa-trash"></i></a>
								</div>
							</div>

							{{! Descrição Oculta/Expansível }}
							<div class="item-description">
								<div class="description-body-content">
									{{{item.system.description}}}
								</div>
							</div>
						</li>
					{{/each}}
				</ol>
			</div>
		{{/each}}

		{{! ITENS INVÁLIDOS / OUTROS }}
		{{#if abilities.invalid}}
			<div class="inventory-category invalid-category">
				<div class="inventory-list-header alert-header">
					<span class="col-name"><i class="fas fa-triangle-exclamation"></i> Outros Itens (Não Classificados)</span>
				</div>
				<ol class="inventory-items-list">
					{{#each abilities.invalid as |item id|}}
						<li class="item item-row draggable" data-document-class="Item" data-item-id="{{item._id}}">
							<div class="item-row-main">
								<div class="item-identity flexrow">
									<div class="item-image slide">
										<img src="{{item.img}}" title="{{item.name}}" class="item-toggle" style="cursor: pointer;" />
										<a class="rollable" data-roll-type="item" data-action="onRoll"><i class="fa-solid fa-dice-d20"></i></a>
									</div>
									<span class="item-name item-toggle" style="cursor: pointer;" data-tooltip="{{item.name}}">{{item.name}}</span>
								</div>

								<div class="item-meta-col col-type"><span class="badge-cat">—</span></div>
								<div class="item-meta-col col-cost"><span class="badge-cat highlight">{{item.system.cost}}</span></div>
								<div class="item-meta-col col-exec">
									<span class="badge-cat">
										{{#if item.system.activation}}{{localize
												(concat "op.executionChoices." item.system.activation)
											}}{{else}}—{{/if}}
									</span>
								</div>

								<div class="item-meta-col col-controls">
									<a class="item-btn item-edit" data-action="viewDoc"><i class="fas fa-edit"></i></a>
									<a class="item-btn btn-delete" data-action="deleteDoc"><i class="fas fa-trash"></i></a>
								</div>
							</div>
							<div class="item-description">
								<div class="description-body-content">{{{item.system.description}}}</div>
							</div>
						</li>
					{{/each}}
				</ol>
			</div>
		{{/if}}
	</div>
</section>