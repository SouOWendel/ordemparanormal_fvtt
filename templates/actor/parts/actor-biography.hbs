{{! Biography Tab }}
<section class="tab flexcol biography inventory-tab {{tab.cssClass}}" data-group="primary" data-tab="biography">

	<div
		class="inventory-list-container scrollable-inventory"
		style="padding: 15px; display: flex; flex-direction: column; gap: 20px;"
	>

		{{! SEÇÃO 1: BIOGRAFIA }}
		<div class="inventory-category dossier-section">
			<div class="inventory-list-header">
				<span class="col-name"><i class="fas fa-fingerprint"></i> Biografia do Agente</span>
			</div>

			<div class="dossier-editor-container">
				{{#if editable}}
					<prose-mirror
						name="system.biography"
						data-document-u-u-i-d="{{actor.uuid}}"
						value="{{system.biography}}"
						collaborate="true"
						toggled="true"
					>
						{{{enrichedBiography}}}
					</prose-mirror>
				{{else}}
					<div class="locked-content">
						{{{enrichedBiography}}}
					</div>
				{{/if}}
			</div>
		</div>

		{{! SEÇÃO 2: OBJETIVOS }}
		<div class="inventory-category dossier-section">
			<div class="inventory-list-header">
				<span class="col-name"><i class="fas fa-bullseye-arrow"></i> Objetivos da Missão</span>
			</div>

			<div class="dossier-editor-container">
				{{#if editable}}
					<prose-mirror
						name="system.goals"
						data-document-u-u-i-d="{{actor.uuid}}"
						value="{{system.goals}}"
						collaborate="true"
						toggled="true"
					>
						{{{enrichedGoals}}}
					</prose-mirror>
				{{else}}
					<div class="locked-content">
						{{{enrichedGoals}}}
					</div>
				{{/if}}
			</div>
		</div>

	</div>
</section>