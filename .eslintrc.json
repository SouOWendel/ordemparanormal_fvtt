{
	"env": {
		"browser": true,
		"es2021": true
	},
	"extends": ["eslint:recommended", "google", "plugin:prettier/recommended"],
	"parserOptions": {
		"ecmaVersion": "latest",
		"sourceType": "module"
	},
	"rules": {
		"valid-jsdoc": "off",
		"require-jsdoc": "off",
		"no-undef": "off",
		"prefer-rest-params": "off",
		"new-cap": "off"
	},
	"overrides": [
		{
			"files": ["tests/**/*.mjs"],
			"env": {
				"browser": false,
				"node": true
			}
		}
	]
}
